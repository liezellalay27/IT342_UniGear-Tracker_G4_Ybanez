# Database Configuration (Supabase PostgreSQL)
DB_URL=jdbc:postgresql://your-supabase-host:6543/postgres
DB_USERNAME=postgres.your_project_id
DB_PASSWORD=your_database_password

# Server Configuration
SERVER_PORT=8080

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Application Configuration
APP_NAME=unigear-tracker

# Google OAuth2 Configuration
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Configuration (Optional - has defaults)
# JWT_SECRET=your_custom_jwt_secret_key_here
# JWT_EXPIRATION=86400000

# OAuth2 Redirect URI (Optional - has default)
# OAUTH2_REDIRECT_URI=http://localhost:3000
